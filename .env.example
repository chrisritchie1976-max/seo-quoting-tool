# ─── n8n webhook (Ahrefs + Claude enrichment) ───────────────────────────────
# Paste your n8n webhook URL here after setting up the workflow
REACT_APP_N8N_WEBHOOK_URL=https://YOUR_N8N_INSTANCE/webhook/seo-quote

# ─── Google Sheets (optional — for live benchmark config) ────────────────────
# Leave blank to use built-in defaults
REACT_APP_SHEETS_API_KEY=
REACT_APP_SHEET_ID=
